# .env.example - Copy this to .env and fill in your values

# -------------------------
# SECURITY
# -------------------------
SECRET_KEY=your-secret-key-here-generate-new-one
DEBUG=False
ALLOWED_HOSTS=your-domain.onrender.com,yourdomain.com

# -------------------------
# DATABASE
# -------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=auth
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-postgres-host.render.com
DB_PORT=5432

# -------------------------
# JWT
# -------------------------
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
ROTATE_REFRESH_TOKENS=False
BLACKLIST_AFTER_ROTATION=True
AUTH_HEADER_TYPES=Bearer
UPDATE_LAST_LOGIN=True

# -------------------------
# EMAIL SERVICE
# -------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
DEFAULT_FROM_EMAIL=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# -------------------------
# CELERY
# -------------------------
CELERY_BROKER_URL=rediss://your-redis-url:6379/1
CELERY_RESULT_BACKEND=rediss://your-redis-url:6379/1

# -------------------------
# CSRF
# -------------------------
CSRF_TRUSTED_ORIGINS=https://your-api.onrender.com,https://your-frontend.onrender.com

# -------------------------
# ADMIN CREDENTIALS
# -------------------------
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your-admin-password
